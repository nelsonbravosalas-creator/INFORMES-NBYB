# ============================================================================
# INFORMES-NBYB — Variables de entorno
# ============================================================================
# Copia este archivo a .env (que está en .gitignore) y completa los valores.
# En Vercel, configura cada variable en Settings → Environment Variables.
# ============================================================================

# ─── Gemini AI (OCR de placas de equipos HVAC) ──────────────────────────────
# Obtén tu API key en https://aistudio.google.com/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ─── Neon Postgres (base de datos) ──────────────────────────────────────────
# Obtén el connection string en https://console.neon.tech → tu proyecto → Connect
# Formato: postgres://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL="postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/informes_nbyb?sslmode=require"

# ─── Autenticación (opcional, fase 2) ───────────────────────────────────────
# String aleatorio de 32+ caracteres para firmar JWTs.
# Generar: openssl rand -base64 48
JWT_SECRET="cambia-esto-por-un-string-aleatorio-largo-y-secreto"

# ─── URL pública de la app ──────────────────────────────────────────────────
# En desarrollo: http://localhost:3000
# En Vercel: se inyecta automáticamente como VERCEL_URL — no necesario aquí
APP_URL="http://localhost:3000"

# ─── Entorno ────────────────────────────────────────────────────────────────
NODE_ENV="development"
